# Ejemplo de configuración
# Copiar a .env y completar con valores reales

# Configuración del proxy
PROXY_PORT=8080
PROXY_WEB_UI_PORT=8081

# Configuración de seguridad
ZAP_API_PORT=8090
SONARQUBE_PORT=9000

# Configuración de rendimiento
K6_SCRIPT_PATH=/scripts

# Configuración de caos
TOXIPROXY_API_PORT=8474
TOXIPROXY_PROXY_PORT=8475

# API Keys y credenciales (placeholders)
# Nunca commitear valores reales
API_KEY=tu_api_key_aqui
SECURE_TOKEN=token_seguro_aqui
DATABASE_PASSWORD=password_de_ejemplo